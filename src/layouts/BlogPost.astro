---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, author, tags, headings = [] } = Astro.props;

// Estimate reading time (rough: 200 words/min)
const slotContent = await Astro.slots.render('default');
const wordCount = slotContent.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} — GenAI System Design`}
			description={description}
			image={heroImage}
			article={{
				publishedTime: pubDate.toISOString(),
				author: author || 'Ashish Bhutani',
				tags: tags || [],
			}}
		/>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.post-grid {
				display: grid;
				grid-template-columns: min(800px, calc(100% - 2em));
				justify-content: center;
				gap: 0;
				padding: 1em;
			}
			@media (min-width: 1100px) {
				.post-grid {
					grid-template-columns: 220px min(800px, calc(100% - 280px)) 1fr;
					justify-content: start;
					gap: 0 2em;
					padding: 1em 2em;
					max-width: 1300px;
					margin: 0 auto;
				}
			}
			.hero-image {
				grid-column: 1 / -1;
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--shadow-lg);
			}
			.prose {
				grid-column: 1;
				max-width: 100%;
				padding: 1em 0;
				color: var(--text-primary);
				min-width: 0;
			}
			@media (min-width: 1100px) {
				.prose {
					grid-column: 2;
				}
			}
			.toc-column {
				display: none;
			}
			@media (min-width: 1100px) {
				.toc-column {
					display: block;
					grid-column: 1;
					grid-row: 2;
				}
			}
			.title {
				margin-bottom: 1.5em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				line-height: 1.2;
			}
			.meta {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1em;
				margin-bottom: 0.75em;
				color: var(--text-secondary);
				font-size: 0.9em;
			}
			.meta-divider {
				color: var(--border-color);
			}
			.author {
				font-weight: 600;
				color: var(--text-primary);
			}
			.tags-list {
				display: flex;
				justify-content: center;
				gap: 0.5em;
				flex-wrap: wrap;
				margin-top: 0.75em;
			}
			.tag {
				background: var(--bg-secondary);
				color: var(--text-primary);
				padding: 0.2em 0.6em;
				border-radius: 4px;
				font-size: 0.8em;
				text-decoration: none;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
			}
			.toc-mobile-wrapper {
				display: block;
			}
			@media (min-width: 1100px) {
				.toc-mobile-wrapper {
					display: none;
				}
			}
			.back-link {
				display: inline-block;
				margin-top: 3em;
				padding-top: 1.5em;
				border-top: 1px solid var(--border-color);
				font-weight: 600;
			}
			.diagram-wrapper {
				position: relative;
				margin: 1.5em 0;
				overflow-x: auto;
			}
			.diagram-expand-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.35em;
				margin-top: 0.5em;
				padding: 0.3em 0.75em;
				font-size: 0.8em;
				color: var(--text-secondary);
				background: var(--bg-secondary);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				cursor: pointer;
				transition: background 0.15s, color 0.15s;
			}
			.diagram-expand-btn:hover {
				background: var(--accent-color, #6366f1);
				color: #fff;
				border-color: transparent;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="post-grid">
					<div class="hero-image" style="grid-column: 1 / -1;">
						{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
					</div>
					<div class="prose">
						<div class="title">
							<div class="meta">
								<span class="author">{author || 'Ashish Bhutani'}</span>
								<span class="meta-divider">&middot;</span>
								<FormattedDate date={pubDate} />
								<span class="meta-divider">&middot;</span>
								<span>{readingTime} min read</span>
							</div>
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
							<h1>{title}</h1>
							{tags && tags.length > 0 && (
								<div class="tags-list">
									{tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							)}
						</div>
						<div class="toc-mobile-wrapper">
							<TableOfContents headings={headings} mobile={true} />
						</div>
						<slot />
						<a href="/blog" class="back-link">&larr; Back to all posts</a>
					</div>
					<div class="toc-column">
						<TableOfContents headings={headings} />
					</div>
				</div>
			</article>
		</main>
		<Footer />

		<!-- Diagram lightbox modal -->
		<div id="diagram-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.85);align-items:center;justify-content:center;padding:1rem;">
			<div id="diagram-modal-inner" style="position:relative;background:var(--bg-primary,#fff);border-radius:12px;padding:2.5rem 1.5rem 1.5rem;width:92vw;max-height:90vh;overflow:auto;box-shadow:0 8px 40px rgba(0,0,0,0.4);">
				<button id="diagram-modal-close" aria-label="Close" style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:1px solid var(--border-color,#ccc);border-radius:6px;padding:0.2rem 0.6rem;font-size:1rem;cursor:pointer;line-height:1.4;">✕ Close</button>
				<div id="diagram-modal-content"></div>
			</div>
		</div>

		<!-- Mermaid -->
		<script type="module">
			import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';

			const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
			mermaid.initialize({
				startOnLoad: false,
				theme: isDark ? 'dark' : 'default',
				fontSize: 16,
				flowchart: { htmlLabels: true, curve: 'basis', padding: 20 },
				sequence: { useMaxWidth: false },
			});

			document.querySelectorAll('pre').forEach(pre => {
				const code = pre.querySelector('code');
				const isMermaid = pre.dataset.language === 'mermaid' ||
								  (code && code.className.includes('language-mermaid')) ||
								  pre.className.includes('mermaid');

				if(isMermaid) {
					const mermaidDiv = document.createElement('div');
					mermaidDiv.className = 'mermaid';
					mermaidDiv.textContent = code ? code.textContent : pre.textContent;
					pre.replaceWith(mermaidDiv);
				}
			});

			await mermaid.run();

			// Wrap each rendered diagram with an expand button
			const modal = document.getElementById('diagram-modal');
			const modalContent = document.getElementById('diagram-modal-content');
			const modalClose = document.getElementById('diagram-modal-close');

			document.querySelectorAll('.mermaid').forEach(div => {
				const wrapper = document.createElement('div');
				wrapper.className = 'diagram-wrapper';
				div.parentNode.insertBefore(wrapper, div);
				wrapper.appendChild(div);

				const btn = document.createElement('button');
				btn.className = 'diagram-expand-btn';
				btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand';
				btn.setAttribute('aria-label', 'Expand diagram');
				wrapper.appendChild(btn);

				btn.addEventListener('click', () => {
					const origSvg = div.querySelector('svg');
					if (!origSvg) return;
					const svg = origSvg.cloneNode(true);
					// Strip Mermaid's fixed dimensions so the SVG fills the modal
					const vb = svg.getAttribute('viewBox') || `0 0 ${svg.getAttribute('width') || 800} ${svg.getAttribute('height') || 400}`;
					svg.setAttribute('viewBox', vb);
					svg.removeAttribute('width');
					svg.removeAttribute('height');
					svg.style.cssText = 'width:100%;height:auto;display:block;';
					modalContent.innerHTML = '';
					modalContent.appendChild(svg);
					modal.style.display = 'flex';
					document.body.style.overflow = 'hidden';
				});
			});

			function closeModal() {
				modal.style.display = 'none';
				document.body.style.overflow = '';
				modalContent.innerHTML = '';
			}

			modalClose.addEventListener('click', closeModal);
			modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
			document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
		</script>

		<!-- Table wrappers -->
		<script>
			document.querySelectorAll('.prose table').forEach(table => {
				if (table.parentElement?.classList.contains('table-wrapper')) return;
				const wrapper = document.createElement('div');
				wrapper.className = 'table-wrapper';
				table.parentNode?.insertBefore(wrapper, table);
				wrapper.appendChild(table);
			});
		</script>

		<!-- Code copy buttons -->
		<script>
			document.querySelectorAll('.prose pre').forEach(pre => {
				if (pre.dataset.language === 'mermaid') return;
				if (pre.querySelector('.code-copy-btn')) return;
				const btn = document.createElement('button');
				btn.className = 'code-copy-btn';
				btn.textContent = 'Copy';
				btn.addEventListener('click', async () => {
					const code = pre.querySelector('code');
					const text = code ? code.textContent || '' : pre.textContent || '';
					await navigator.clipboard.writeText(text);
					btn.textContent = 'Copied!';
					setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
				});
				pre.style.position = 'relative';
				pre.appendChild(btn);
			});
		</script>

		<!-- TOC active section highlight -->
		<script>
			const tocLinks = document.querySelectorAll('.toc-link');
			if (tocLinks.length > 0) {
				const headingEls = Array.from(tocLinks).map(link => {
					const id = link.getAttribute('href')?.slice(1);
					return id ? document.getElementById(id) : null;
				}).filter(Boolean) as HTMLElement[];

				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							tocLinks.forEach(l => l.classList.remove('active'));
							document.querySelectorAll(`.toc-link[href="#${entry.target.id}"]`).forEach(l => l.classList.add('active'));
						}
					});
				}, { rootMargin: '-80px 0px -70% 0px' });

				headingEls.forEach(el => observer.observe(el));
			}
		</script>

		<!-- Image lightbox + captions -->
		<script>
			document.querySelectorAll('.prose img:not(.no-lightbox)').forEach(img => {
				const imgEl = img as HTMLImageElement;
				// Add caption from alt text
				const alt = imgEl.getAttribute('alt');
				if (alt && alt.trim() && !imgEl.parentElement?.classList.contains('prose-img-wrapper')) {
					const wrapper = document.createElement('figure');
					wrapper.className = 'prose-img-wrapper';
					imgEl.parentNode?.insertBefore(wrapper, imgEl);
					wrapper.appendChild(imgEl);
					const caption = document.createElement('figcaption');
					caption.className = 'prose-img-caption';
					caption.textContent = alt.replace(/\\n/g, '\n');
					wrapper.appendChild(caption);
				}

				imgEl.addEventListener('click', () => {
					const overlay = document.createElement('div');
					overlay.className = 'lightbox-overlay';
					const clone = document.createElement('img');
					clone.src = imgEl.src;
					clone.alt = imgEl.alt;
					overlay.appendChild(clone);

					if (alt && alt.trim()) {
						const cap = document.createElement('div');
						cap.className = 'lightbox-caption';
						cap.textContent = alt.replace(/\\n/g, '\n');
						overlay.appendChild(cap);
					}

					overlay.addEventListener('click', () => overlay.remove());
					document.addEventListener('keydown', function handler(e) {
						if (e.key === 'Escape') {
							overlay.remove();
							document.removeEventListener('keydown', handler);
						}
					});
					document.body.appendChild(overlay);
				});
			});
		</script>

		<!-- Heading anchor copy-to-clipboard -->
		<script>
			document.querySelectorAll('.heading-anchor').forEach(anchor => {
				anchor.addEventListener('click', (e) => {
					e.preventDefault();
					const href = (anchor as HTMLAnchorElement).href;
					navigator.clipboard.writeText(href);
					history.pushState(null, '', (anchor as HTMLAnchorElement).getAttribute('href') || '');
				});
			});
		</script>
	</body>
</html>
