flowchart LR
    AR["Application Received"] --> DC["Document Collection"]
    DC --> DE["Data Extraction"]
    DE --> CV["Cross-Doc Verification"]
    CV --> CC["Compliance Check"]
    CC --> UN["Underwriting Narrative"]
    UN --> DEC{"Decision"}
    DEC -->|"Approved"| CL["Closing"]
    DEC -->|"More info needed"| DC
    DEC -->|"Rejected"| RJ["Rejected"]

    DE -.->|"Low confidence"| HR1["Human Review"]
    HR1 -.->|"Corrected"| CV
    CV -.->|"Unresolved flags"| HR2["Human Review"]
    HR2 -.->|"Resolved"| CC

