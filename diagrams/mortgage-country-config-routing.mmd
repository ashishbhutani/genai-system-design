flowchart TD
    APP["Incoming Application"] --> CR{"Country Router"}

    CR -->|"country=UK"| UK["UK Config"]
    CR -->|"country=DE"| DE["Germany Config"]
    CR -->|"country=US"| US["US Config"]

    UK --> DTR1["Doc Types: P60, P45, Council Tax"]
    UK --> CRL1["Compliance: FCA Rules, LTV 75%"]
    UK --> DRP1["Data Residency: Cloud Allowed"]
    UK --> TR1["Tools: Experian UK, Land Registry"]

    DE --> DTR2["Doc Types: Lohnsteuer, Grundbuch"]
    DE --> CRL2["Compliance: BaFin Rules, LTV 80%"]
    DE --> DRP2["Data Residency: On-Prem Only"]
    DE --> TR2["Tools: SCHUFA, Grundbuchamt API"]

    US --> DTR3["Doc Types: W-2, 1040, HUD-1"]
    US --> CRL3["Compliance: TILA/RESPA, LTV 80%"]
    US --> DRP3["Data Residency: Cloud Allowed"]
    US --> TR3["Tools: Equifax, County Records API"]

    DTR1 & DTR2 & DTR3 --> EP["Extraction Prompts"]
    CRL1 & CRL2 & CRL3 --> RE["Rules Engine"]
    DRP1 & DRP2 & DRP3 --> DP["Data Path Selector"]
    TR1 & TR2 & TR3 --> TA["Tool Registry"]

    EP & RE & DP & TA --> WE["Workflow Engine"]

